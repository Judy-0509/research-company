# GLM API Key (required)
# Get your key from: https://open.bigmodel.cn or https://api.z.ai
GLM_API_KEY=your_glm_api_key_here

# Auto collection settings
AUTO_COLLECT_ON_START=false
ENABLE_SCHEDULED_COLLECT=false
COLLECT_INTERVAL_HOURS=2

# Summarize worker settings
SUMMARIZE_BATCH_SIZE=20
SUMMARIZE_WALL_CLOCK=90
